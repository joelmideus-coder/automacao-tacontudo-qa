# ============================================================
# Configuração de Ambiente - Test Framework
# Copie este arquivo como .env e preencha com seus dados
# ============================================================

# Aplicação a ser testada (nome da pasta em apps/)
APP=tuaagenda

# Credenciais de login
EMAIL_TESTE=seu@email.com
SENHA_TESTE=sua-senha

# URL base da aplicação
BASE_URL=https://dev.tuaagenda.app

# Nível do teste (smoke, critical, complete, full)
TEST_LEVEL=critical

# Modo headless (true = sem abrir navegador)
HEADLESS=true

# Ambiente (dev, staging, prod)
APP_ENV=dev
